# --- core ---
NODE_ENV=development
PORT=3000
# Comma-separated allowlist; the web dev server runs on 3110
CORS_ORIGINS=http://localhost:3110
LOG_LEVEL=info
SWAGGER_ENABLED=true

# --- mock mode (true = seeded in-memory data; no database or AI keys needed) ---
MOCK_MODE=false

# --- demo data (true = seed the Hebrew mock world into the DB on boot; keep FALSE in prod) ---
SEED_DEMO_DATA=false

# --- database (Supabase: postgres://...?sslmode=require; session pooler 5432 / transaction pooler 6543) ---
DATABASE_URL=postgres://app:app@localhost:5432/app

# --- auth (JWT_SECRET is REQUIRED in production, min 32 chars) ---
JWT_SECRET=dev-only-secret-change-me-32-chars!!
JWT_EXPIRES_IN=30d

# --- audio upload ---
UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=26214400

# --- transcription (ElevenLabs Scribe) ---
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=scribe_v2
TRANSCRIBE_LANGUAGE=he

# --- summaries + next-meeting reports (Anthropic Claude) ---
SUMMARY_ENABLED=true
ANTHROPIC_API_KEY=
SUMMARY_MODEL=claude-haiku-4-5
MAX_TRANSCRIPT_CHARS=40000

# --- assistant chat ("שאל את סנסיי"; OpenAI, or MOCK_MODE mock) ---
ASSISTANT_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# The assistant's tools call back into this API (self base URL)
ASSISTANT_SELF_BASE_URL=http://localhost:3000
# true (demo only) lets the tools reach any GET on this API, including PHI
ASSISTANT_ALLOW_ALL_GETS=false
# Optional output-token cap for one reply
ASSISTANT_MAX_OUTPUT_TOKENS=
ASSISTANT_MAX_QUESTION_CHARS=4000
# Optional total-input-token budget (trims oldest history when set)
ASSISTANT_MAX_TOTAL_INPUT_TOKENS=

# --- assistant tracing (Langfuse; disabled by default) ---
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=
