# --- core ---
NODE_ENV=development
PORT=3000
# Comma-separated allowlist; the web dev server runs on 3110
CORS_ORIGINS=http://localhost:3110
LOG_LEVEL=info
SWAGGER_ENABLED=true

# --- mock mode (true = seeded in-memory data; no database or AI keys needed) ---
MOCK_MODE=false

# --- database (Supabase: postgres://...?sslmode=require; session pooler 5432 / transaction pooler 6543) ---
DATABASE_URL=postgres://app:app@localhost:5432/app

# --- auth (JWT_SECRET is REQUIRED in production, min 32 chars) ---
JWT_SECRET=dev-only-secret-change-me-32-chars!!
JWT_EXPIRES_IN=30d

# --- audio upload ---
UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=26214400

# --- transcription (ElevenLabs Scribe) ---
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=scribe_v2
TRANSCRIBE_LANGUAGE=he

# --- summaries + next-meeting reports (Anthropic Claude) ---
SUMMARY_ENABLED=true
ANTHROPIC_API_KEY=
SUMMARY_MODEL=claude-haiku-4-5
MAX_TRANSCRIPT_CHARS=40000
